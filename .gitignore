# Secrets and local config
.env
.env.*
!.env.example

# Local state, bind-mounted into the container (/data). Holds the Basecamp
# OAuth credentials (full-scope token) and the SQLite history — never commit.
/data/
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm
*.db

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

