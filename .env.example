# Copy this file to `.env` and adjust as needed. Values shown are the defaults.

# How often (in seconds) to poll Basecamp for newly assigned to-dos.
POLL_INTERVAL_SECONDS=5

# Path to the SQLite database used for de-duplicating processed to-dos.
DB_PATH=/data/bcworker.sqlite3

# Name or absolute path of the Basecamp CLI binary.
BASECAMP_BIN=basecamp

# Directory holding the Basecamp CLI credentials (under the ./data mount).
# Must end in `/basecamp` (the CLI reads $XDG_CONFIG_HOME/basecamp).
BASECAMP_CONFIG_DIR=/data/basecamp

# The single Basecamp project the worker serves. Tasks are taken from here.
# Required in production; 0 disables project filtering (used only in tests).
BASECAMP_PROJECT_ID=

# Basecamp account id. Optional and usually unnecessary — the worker auto-detects
# it when the login has a single account. Set it only if the login can access
# several accounts.
# BASECAMP_ACCOUNT_ID=

# Per-command timeout (in seconds) for Basecamp CLI invocations.
BASECAMP_TIMEOUT_SECONDS=30

# Logging level: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Directory holding the *.sql migration files (set inside the image already).
MIGRATIONS_DIR=/app/migrations

# --- Claude Code ------------------------------------------------------------

# Claude Code binary, per-run timeout (seconds), workspace and OAuth config dirs.
CLAUDE_BIN=claude
CLAUDE_TIMEOUT_SECONDS=900
CLAUDE_WORKSPACE_DIR=/data/workspace
CLAUDE_CONFIG_DIR=/data/claude
# Permission mode for headless runs. If MCP servers hang on a trust prompt,
# switch to `bypassPermissions`.
CLAUDE_PERMISSION_MODE=acceptEdits

# Note: the worker no longer syncs knowledge from Basecamp Docs & Files. Place
# CLAUDE.md, .mcp.json, documents/ and .claude/skills/ directly under
# ./data/workspace/ (the bind-mounted claude working dir) yourself.

# --- Follow-up edits & code-save lifecycle ----------------------------------

# How often (seconds) to poll for new customer comments and to advance the
# code-save flow, and how long after a task is completed to post the "save the
# code?" comment. CODE_SAVE_REPLY_TIMEOUT_SECONDS: how long to wait for the
# customer's yes/no answer before giving up (and not saving); default 7 days.
COMMENT_POLL_SECONDS=30
CODESAVE_POLL_SECONDS=30
CODE_SAVE_DELAY_SECONDS=300
CODE_SAVE_REPLY_TIMEOUT_SECONDS=604800
# Max number of tasks handled concurrently.
TASK_MAX_CONCURRENCY=1

# --- MCP server credentials (consumed by .mcp.json via ${VAR}) --------------

# MySQL. No database is pinned, so Claude can query every database the user can
# access (fully-qualified `db.table` references).
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=

# Spark (login + password).
SPARK_HOST=
SPARK_PORT=
SPARK_USER=
SPARK_PASSWORD=
